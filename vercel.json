{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "functions": {
    "api/**/*.ts": {
      "maxDuration": 30
    }
  },
  "rewrites": [
    {
      "source": "/product-feed.xml",
      "destination": "/api/product-feed"
    },
    {
      "source": "/((?!api/|assets/|favicon|src/).*)",
      "destination": "/index.html"
    }
  ]
}
