PORT=4000
DATABASE_URL=postgresql://user:password@host:5432/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# SMTP configuration (required for live sends)
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-username
SMTP_PASS=your-smtp-password
SMTP_FROM="Research Peptides UK <no-reply@researchpeptide.uk>"
SMTP_REPLY_TO=info@researchpeptide.uk

# Email metadata
EMAIL_ADMIN_TO=info@researchpeptide.uk
EMAIL_BRAND_NAME=Research Peptides UK
EMAIL_SUPPORT_ADDRESS=info@researchpeptide.uk

# Set true locally to log-only without sending.
EMAIL_DRY_RUN=true
